# AthleteView AI Engine Configuration
NODE_ENV=development
API_PORT=3000
JWT_SECRET=change-this-in-production

# AI Engine
AI_ENGINE_HOST=ai-engine
AI_ENGINE_PORT=8001
GPU_DEVICE=0
MODEL_CACHE_DIR=/app/weights
TENSORRT_ENABLED=true

# Streaming
STREAMING_HOST=streaming
STREAMING_PORT=8002
SRT_LISTEN_PORT=9000
RTMP_PORT=1935
HLS_OUTPUT_DIR=/tmp/hls

# Biometrics
BIOMETRICS_HOST=biometrics
BIOMETRICS_PORT=8003
PPG_SAMPLE_RATE=100
ALERT_THRESHOLD_HR_HIGH=190
ALERT_THRESHOLD_HR_LOW=40

# Infrastructure
KAFKA_BROKERS=kafka:9092
REDIS_URL=redis://redis:6379
TIMESCALEDB_URL=postgresql://athleteview:secret@timescaledb:5432/athleteview
CDN_BASE_URL=https://cdn.athleteview.ai

# External Streaming
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2
TWITCH_RTMP_URL=rtmp://live.twitch.tv/app
